# Supabase (Phase 2A)
# Copy this file to .env.local in the repo root and fill in values.
# Get these from: Supabase Dashboard → Project Settings → API

# Required for the app (client and server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for bootstrap and server-side admin (e.g. parent creating child accounts).
# NEVER expose this key client-side or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: OpenAI API key for AI-generated exercises and answer evaluation.
# If unset, the app uses fallback local math questions and exact-match evaluation.
# OPENAI_API_KEY=sk-...

# Optional: E2E only. Used by Playwright session-flow.spec.ts (test process only; never in client).
# After npm run bootstrap:users you can use Liv: liv@noraliva.local with the bootstrap password (see BOOTSTRAP.md).
# TEST_LEARNER_EMAIL=liv@noraliva.local
# TEST_LEARNER_PASSWORD=your-password
